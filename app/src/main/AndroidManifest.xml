<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Фоновая запись тренировки (C1): микрофон + foreground-сервис типа microphone. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Фоновая заливка записи (C3): long-running foreground-воркер WorkManager типа dataSync. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Показ уведомления записи/заливки на Android 13+ (рантайм-разрешение). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".NivelApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nivel">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Nivel.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link возврата из Chrome Custom Tabs после входа через Гречку:
                 nivel://auth/callback?token=<firebaseIdToken>&state=<csrf[~claim]>.
                 Заменяет перехват редиректа в WebView (Google блокирует OAuth в WebView:
                 disallowed_useragent / Error 403). singleTask + onNewIntent доставляют
                 callback в уже запущенную Activity. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="nivel"
                    android:host="auth"
                    android:path="/callback" />
            </intent-filter>
        </activity>

        <!-- Foreground-сервис фоновой записи тренировки (C1). Не экспортируется —
             управляется только изнутри приложения через RecordingController. -->
        <service
            android:name=".service.RecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- C3 (#12): long-running foreground-воркер заливки на Android 14+ требует
             объявить тип foreground-сервиса WorkManager как dataSync. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- C3 (#12): отключаем дефолтную инициализацию WorkManager через App Startup,
             чтобы поднять его on-demand с HiltWorkerFactory (см. NivelApp). -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
