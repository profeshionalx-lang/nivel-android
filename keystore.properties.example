# Шаблон конфигурации подписи release-сборки.
# Скопируй в keystore.properties (он в .gitignore) и заполни своими значениями.
# Используется в app/build.gradle.kts для подписи assembleRelease.
#
# Сгенерировать keystore:
#   keytool -genkey -v -keystore release.keystore -alias nivel \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile — путь к keystore относительно корня репозитория (или абсолютный).

storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=nivel
keyPassword=CHANGE_ME
